# Telegram Bot Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# LinkedIn Job Search Configuration
# Palavras-chave de busca (Ex: Desenvolvedor, Node.js, Frontend)
SEARCH_KEYWORDS=Desenvolvedor,Programador,Engenheiro de Software,Software Engineer,Developer,Analista de Sistemas,Fullstack,Full Stack,Backend,Frontend,Back-end,Front-end

# Tempo de busca em horas (Ex: 1 para buscar vagas da última hora, 24 para últimas 24h)
SEARCH_TIME_HOURS=1

# Número máximo de candidatos permitidos (Coloque 0 para desativar o limite)
MAX_APPLICANTS=50

# Database Configuration
DATABASE_PATH=./data/jobs.db

# Configurações do Scraper
# Intervalo de tempo entre requisições de scraping (em milissegundos) para evitar rate limit
SCRAPER_DELAY_MS=5000

# Planos de estudo (LLM via Groq)
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
# Texto livre com seu perfil/stacks para personalizar os planos
CANDIDATE_PROFILE=Desenvolvedor com foco em TypeScript, Node.js, React/Next.js e APIs. Nível júnior/pleno.

# Em redes corporativas com SSL inspection (erro "self-signed certificate"):
ALLOW_INSECURE_TLS=false

