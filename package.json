{
  "name": "linkedin-job-bot",
  "version": "1.0.0",
  "description": "Automated LinkedIn job scraper and Telegram notification bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.bot.json && next build",
    "build:bot": "tsc -p tsconfig.bot.json",
    "build:dashboard": "next build",
    "start": "node dist/index.js",
    "dev": "ts-node --project tsconfig.bot.json src/index.ts",
    "dev:bot": "ts-node --project tsconfig.bot.json src/index.ts",
    "dev:once": "ts-node --project tsconfig.bot.json src/index.ts --once",
    "dev:dashboard": "next dev",
    "test": "jest",
    "postinstall": "playwright install chromium"
  },
  "keywords": [
    "linkedin",
    "scraper",
    "telegram-bot",
    "playwright",
    "typescript"
  ],
  "author": "Kevin",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.2",
    "cheerio": "^1.0.0-rc.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "node-cron": "^3.0.3",
    "playwright": "^1.45.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.9.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/sqlite3": "^3.1.11",
    "autoprefixer": "^10.4.21",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
